{
  "name": "aine",
  "version": "0.1.0",
  "description": "Agent-agnostic diff viewer and code review tool",
  "license": "MIT",
  "bin": {
    "aine": "./cli.ts"
  },
  "type": "module",
  "scripts": {
    "build": "bun ./node_modules/.bin/vite build",
    "dev": "bun --watch cli.ts & bun ./node_modules/.bin/vite dev & wait",
    "start": "bun cli.ts",
    "test": "vitest run --config tests/vitest.config.ts",
    "test:watch": "vitest --config tests/vitest.config.ts",
    "test:api": "vitest run --config tests/vitest.config.ts api/",
    "test:unit": "vitest run --config tests/vitest.config.ts unit/",
    "test:e2e": "bunx playwright test --config tests/playwright.config.ts"
  },
  "dependencies": {
    "@pierre/diffs": "latest"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "svelte": "^5.55.0",
    "vite": "^8.0.2",
    "vite-plugin-singlefile": "^2.3.2",
    "vitest": "^4.1.2"
  }
}
